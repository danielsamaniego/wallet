{
  "version": 2,
  "regions": ["dub1"],
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node", "config": { "maxDuration": 25 } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.ts" }
  ],
  "crons": [
    {
      "path": "/internal/cron/expire-holds",
      "schedule": "* * * * *"
    },
    {
      "path": "/internal/cron/cleanup-idempotency",
      "schedule": "0 * * * *"
    }
  ]
}
