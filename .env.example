# Database
DATABASE_URL=postgresql://wallet:wallet@localhost:5432/wallet?schema=public
# DIRECT_URL is used by Prisma for migrations (Supabase direct connection, port 5432).
# In local dev, defaults to DATABASE_URL if not set.
# DIRECT_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres

# Server
HTTP_PORT=3000
LOG_LEVEL=info

# Vercel Cron Jobs (auto-injected by Vercel in production)
# CRON_SECRET=

# Platform auth (for seeding / admin)
# ADMIN_API_KEY=change-me-in-production
