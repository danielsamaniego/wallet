# Database
DATABASE_URL=postgresql://wallet:wallet@localhost:5432/wallet?schema=public
# DIRECT_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres

# Server
HTTP_PORT=3000
LOG_LEVEL=info

# Cron (auto-injected by Vercel in prod)
# CRON_SECRET=

# Wallet lock — per-wallet serialization (requires Redis)
# Set to true + provide REDIS_URL to enable. docker-compose.dev.yml
# enables it automatically against the bundled Redis container.
WALLET_LOCK_ENABLED=false
# REDIS_URL=redis://localhost:6379
# Managed Redis (Upstash, etc.): rediss://default:<TOKEN>@<host>:<port>

# Transport for the Redis client.
#   tcp  — ioredis persistent connection. ~1-5ms/op. Default. Use locally
#          or on long-lived processes.
#   rest — @upstash/redis over HTTPS. ~10-30ms/op. Stateless per-request;
#          ideal for serverless (Vercel, Lambda) where cold bursts would
#          otherwise exhaust Upstash's per-DB connection quota (EMAXCONN).
#          Parses host+token out of REDIS_URL.
# WALLET_LOCK_TRANSPORT=tcp

# Lock tuning (leave commented to use defaults)
# WALLET_LOCK_TTL_MS=10000
# WALLET_LOCK_WAIT_MS=5000
# WALLET_LOCK_RETRY_MS=50
