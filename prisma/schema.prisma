generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

/// Platform that integrates the wallet service. Authenticates via API key.
model Platform {
  id         String   @id /// UUID v7, app-generated
  name       String
  apiKeyHash String   @map("api_key_hash")
  apiKeyId   String   @unique @map("api_key_id") /// Public key identifier
  status     String   @default("active") /// active | suspended | revoked
  createdAt  BigInt   @map("created_at") /// Unix ms
  updatedAt  BigInt   @map("updated_at") /// Unix ms
  wallets    Wallet[]

  @@map("platforms")
}

/// User wallet. Balance stored as integer minor units (smallest currency unit).
/// Optimistic locking via version field.
model Wallet {
  id                 String        @id /// UUID v7, app-generated
  ownerId            String        @map("owner_id") /// External user ID from platform
  platformId         String        @map("platform_id")
  platform           Platform      @relation(fields: [platformId], references: [id])
  currencyCode       String        @map("currency_code") /// ISO 4217 (USD, EUR, etc.)
  cachedBalanceMinor BigInt        @default(0) @map("cached_balance_minor") /// Integer minor units
  status             String        @default("active") /// active | frozen | closed
  version            Int           @default(1) /// Optimistic locking
  isSystem           Boolean       @default(false) @map("is_system") /// True for system/omnibus wallets
  createdAt          BigInt        @map("created_at") /// Unix ms
  updatedAt          BigInt        @map("updated_at") /// Unix ms
  transactions              Transaction[] @relation("WalletTransactions")
  counterpartTransactions   Transaction[] @relation("CounterpartTransactions")
  ledgerEntries             LedgerEntry[]
  holds                     Hold[]

  @@unique([ownerId, platformId, currencyCode])
  @@index([platformId, status])
  @@map("wallets")
}

/// Groups all transactions and ledger entries for a single financial operation (journal entry).
/// One movement per deposit, withdrawal, transfer, hold capture, or adjustment. Entries must sum to zero.
model Movement {
  id            String        @id /// UUID v7, app-generated
  type          String /// deposit | withdrawal | transfer | hold_capture | adjustment
  reason        String? /// Human-readable reason (used for adjustments)
  createdAt     BigInt        @map("created_at") /// Unix ms

  transactions  Transaction[]
  ledgerEntries LedgerEntry[]

  @@map("movements")
}

/// Financial transaction record. amount_minor is always positive.
model Transaction {
  id                  String        @id /// UUID v7, app-generated
  walletId            String        @map("wallet_id")
  wallet              Wallet        @relation("WalletTransactions", fields: [walletId], references: [id])
  counterpartWalletId String?       @map("counterpart_wallet_id")
  counterpartWallet   Wallet?       @relation("CounterpartTransactions", fields: [counterpartWalletId], references: [id])
  type                String /// deposit | withdrawal | transfer_in | transfer_out | hold_capture | adjustment_credit | adjustment_debit
  amountMinor         BigInt        @map("amount_minor") /// Always positive, integer minor units
  status              String        @default("completed") /// completed | failed | reversed
  idempotencyKey      String?       @map("idempotency_key")
  reference           String? /// External reference from caller
  metadata            Json? /// Arbitrary JSON metadata
  holdId              String?       @map("hold_id") /// If from a captured hold
  movementId          String        @map("movement_id")
  movement            Movement      @relation(fields: [movementId], references: [id])
  createdAt           BigInt        @map("created_at") /// Unix ms

  ledgerEntries LedgerEntry[]

  @@index([walletId, createdAt])
  @@index([walletId, type, createdAt])
  @@index([walletId, status, createdAt])
  @@index([walletId, amountMinor])
  @@index([idempotencyKey])
  @@index([movementId])
  @@map("transactions")
}

/// Immutable double-entry ledger entry. Append-only — never update or delete.
/// Protected by DB trigger and REVOKE permissions.
model LedgerEntry {
  id                String      @id /// UUID v7, app-generated
  transactionId     String      @map("transaction_id")
  transaction       Transaction @relation(fields: [transactionId], references: [id])
  walletId          String      @map("wallet_id")
  wallet            Wallet      @relation(fields: [walletId], references: [id])
  entryType         String      @map("entry_type") /// CREDIT | DEBIT
  amountMinor       BigInt      @map("amount_minor") /// + for credit, - for debit
  balanceAfterMinor BigInt      @map("balance_after_minor") /// Balance snapshot after this entry
  movementId        String      @map("movement_id")
  movement          Movement    @relation(fields: [movementId], references: [id])
  createdAt         BigInt      @map("created_at") /// Unix ms

  @@index([walletId, createdAt])
  @@index([walletId, entryType, createdAt])
  @@index([transactionId])
  @@index([movementId])
  @@map("ledger_entries")
}

/// Hold (authorization) — reserves funds without moving them.
model Hold {
  id          String  @id /// UUID v7, app-generated
  walletId    String  @map("wallet_id")
  wallet      Wallet  @relation(fields: [walletId], references: [id])
  amountMinor BigInt  @map("amount_minor") /// Always positive, integer minor units
  status      String  @default("active") /// active | captured | voided | expired
  reference   String?
  expiresAt   BigInt? @map("expires_at") /// Unix ms, optional auto-expiry
  createdAt   BigInt  @map("created_at") /// Unix ms
  updatedAt   BigInt  @map("updated_at") /// Unix ms

  @@index([walletId, status])
  @@map("holds")
}

/// Idempotency record — prevents duplicate financial operations. TTL 48h.
model IdempotencyRecord {
  id             String @id /// UUID v7, app-generated
  idempotencyKey String @map("idempotency_key")
  platformId     String @map("platform_id")
  requestHash    String @default("") @map("request_hash") /// SHA-256 of request body for payload mismatch detection
  responseStatus Int    @map("response_status")
  responseBody   Json   @map("response_body")
  createdAt      BigInt @map("created_at") /// Unix ms
  expiresAt      BigInt @map("expires_at") /// Unix ms

  @@unique([idempotencyKey, platformId])
  @@map("idempotency_records")
}
